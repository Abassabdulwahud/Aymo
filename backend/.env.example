APP_NAME=AYMO Notebook API
APP_ENV=development
DATABASE_URL=postgresql+psycopg2://postgres:postgres@localhost:5432/aymo
UPLOADS_DIR=uploads
UPLOADS_BASE_URL=/uploads
DATABASE_POOL_SIZE=10
DATABASE_MAX_OVERFLOW=20
JWT_SECRET_KEY=
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=60
CONTENT_ENCRYPTION_KEY=
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/1
CELERY_TASK_ALWAYS_EAGER=true
AI_CACHE_TTL_SECONDS=900
TRANSCRIPTION_CACHE_TTL_SECONDS=86400
AI_MEMORY_WINDOW_SIZE=10
AI_MAX_CONTEXT_TOKENS=12000
PASSWORD_RESET_EXPIRE_MINUTES=15
PASSWORD_RESET_BASE_URL=http://127.0.0.1:8010/web/merged-preview.html
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=your_email@example.com
SMTP_PASSWORD=your_app_password
SMTP_FROM_EMAIL=your_email@example.com
SMTP_FROM_NAME=AYMO Notebook
SMTP_USE_TLS=true
GOOGLE_CLIENT_ID=your_google_client_id.apps.googleusercontent.com
APPLE_CLIENT_ID=com.yourcompany.aymo
APPLE_REDIRECT_URI=https://auth.yourdomain.com/apple/callback
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1-mini
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash
DEEPSEEK_API_KEY=
DEEPSEEK_MODEL=deepseek-chat
TESSERACT_CMD=
VISION_API_URL=
VISION_API_KEY=
TRANSCRIPTION_PROVIDER=faster_whisper
TRANSCRIPTION_MODEL=small

# ── Storage Provider ──────────────────────────────────────────────────────────
FILE_STORAGE_PROVIDER=local
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
CLOUDINARY_FOLDER=aymo

