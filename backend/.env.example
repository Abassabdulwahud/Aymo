APP_NAME=AYMO Notebook API
APP_ENV=development
DATABASE_URL=postgresql+psycopg2://postgres:postgres@localhost:5432/aymo
JWT_SECRET_KEY=
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=60
PASSWORD_RESET_EXPIRE_MINUTES=15
PASSWORD_RESET_BASE_URL=http://127.0.0.1:8010/web/merged-preview.html
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=your_email@example.com
SMTP_PASSWORD=your_app_password
SMTP_FROM_EMAIL=your_email@example.com
SMTP_FROM_NAME=AYMO Notebook
SMTP_USE_TLS=true
GOOGLE_CLIENT_ID=your_google_client_id.apps.googleusercontent.com
APPLE_CLIENT_ID=com.yourcompany.aymo
APPLE_REDIRECT_URI=https://auth.yourdomain.com/apple/callback
